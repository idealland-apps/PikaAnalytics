# PikaAnalytics Environment Variables Configuration
# Copy this file to .env and uncomment/modify the variables you need

# ===========================================
# Backend Runtime Environment Variables
# ===========================================

# Data directory path where SQLite databases and logs are stored
# For Docker deployment, this should match the container path
DATA_PATH=/app/data

# GeoLite2 database path for IP geolocation analysis (optional)
# Download GeoLite2-City.mmdb and GeoLite2-ASN.mmdb from MaxMind
# Sign up at: https://www.maxmind.com/en/geolite2/signup
# GEO_IP_DB_PATH=/app/geolite

# CORS origins - comma-separated list of allowed origins
# Set this for production domains that should access the admin panel
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===========================================
# Frontend Build-time Environment Variables
# ===========================================

# API URL for the frontend to communicate with backend
# Set these when building the frontend for production
REACT_APP_API_URL=https://yourdomain.com/api

# ===========================================
# Development Defaults (when variables are not set)
# ===========================================

# Development defaults for backend:
# DATA_PATH=. (current directory)
# CORS_ORIGINS=http://localhost:3000

# Development defaults for frontend:
# REACT_APP_API_URL=http://localhost:8080/api

# ===========================================
# Docker Compose Usage
# ===========================================

# To use this file with docker-compose:
# 1. Copy this file to .env
# 2. Uncomment and modify the variables you need
# 3. Uncomment the env_file section in docker-compose.yml
# 4. Run: docker-compose up -d
